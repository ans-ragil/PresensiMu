# Prisma CLI requires a local SQLite URL during client generation.
DATABASE_URL=file:./dev.db

# Turso Cloud runtime connection
TURSO_DATABASE_URL=libsql://your-database-your-org.turso.io
TURSO_AUTH_TOKEN=replace-with-a-new-turso-token

# JWT
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=7d

# Local server only (Vercel provides its own runtime configuration)
PORT=5000
NODE_ENV=development

# Optional local/preview origins
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173
