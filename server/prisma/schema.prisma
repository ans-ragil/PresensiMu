generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Division {
  id          String   @id @default(uuid())
  nama        String   @unique
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model Position {
  id          String   @id @default(uuid())
  nama        String   @unique
  description String?
  level       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model Shift {
  id          String   @id @default(uuid())
  nama        String   @unique
  jamMulai    String
  jamSelesai  String
  toleransiMenit Int @default(30)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
}

model User {
  id               String          @id @default(uuid())
  nama             String
  email            String          @unique
  password         String
  role             String          @default("EMPLOYEE")
  noTelp           String?
  nik              String?
  jabatan          String?
  divisi           String?
  alamat           String?
  foto             String?
  tanggalBergabung DateTime?
  isActive         Boolean         @default(true)
  divisiId         String?
  jabatanId        String?
  shiftId          String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  division         Division?       @relation(fields: [divisiId], references: [id])
  position         Position?       @relation(fields: [jabatanId], references: [id])
  shift            Shift?          @relation(fields: [shiftId], references: [id])
  attendance       Attendance[]
  schedule         Schedule[]
  leaveRequests    LeaveRequest[]  @relation("LeaveRequests")
  approvedLeaves   LeaveRequest[]  @relation("ApprovedBy")
  notifications    Notification[]
}

model Attendance {
  id         String    @id @default(uuid())
  userId     String
  tanggal    DateTime
  clockIn    DateTime?
  clockOut   DateTime?
  lokasiIn   String?
  lokasiOut  String?
  fotoIn     String?
  fotoOut    String?
  status     String    @default("ACTIVE")
  keterangan String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tanggal])
}

model Schedule {
  id             String   @id @default(uuid())
  userId         String
  hari           Int
  jamMulai       String
  jamSelesai     String
  shiftType      String   @default("NORMAL")
  toleransiMenit Int      @default(30)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hari])
}

model LeaveRequest {
  id              String   @id @default(uuid())
  userId          String
  tipeIzin        String
  tanggalMulai    DateTime
  tanggalSelesai  DateTime
  keterangan      String?
  bukti           String?
  status          String   @default("PENDING")
  approvedBy      String?
  catatanAdmin    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("LeaveRequests", fields: [userId], references: [id], onDelete: Cascade)
  approver        User?    @relation("ApprovedBy", fields: [approvedBy], references: [id])
}

model Holiday {
  id        String   @id @default(uuid())
  nama      String
  tanggal   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CompanyLocation {
  id        String   @id @default(uuid())
  nama      String
  latitude  Float
  longitude Float
  radius    Int      @default(500)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailSetting {
  id        String   @id @default(uuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  category  String   @default("SISTEM")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model CompanySetting {
  id            String   @id @default(uuid())
  key           String   @unique
  value         String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
